{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "API Monitoring",
      "url": "/d/cwe-explorer-api",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "# 🖥️ Infrastructure Overview"
      }
    },
    {
      "title": "Signed In As",
      "type": "text",
      "gridPos": { "h": 2, "w": 8, "x": 0, "y": 2 },
      "options": {
        "mode": "markdown",
        "content": "👤 **${__user.login}** &nbsp;·&nbsp; ${__user.email}"
      }
    },
    {
      "title": "Dashboard",
      "type": "text",
      "gridPos": { "h": 2, "w": 8, "x": 8, "y": 2 },
      "options": {
        "mode": "markdown",
        "content": "📋 **PureSecure — Infrastructure Monitoring** &nbsp;·&nbsp; Auto-refresh: ${__dashboard.refresh}"
      }
    },
    {
      "title": "Time Range",
      "type": "text",
      "gridPos": { "h": 2, "w": 8, "x": 16, "y": 2 },
      "options": {
        "mode": "markdown",
        "content": "🕒 **${__from:date:YYYY-MM-DD HH:mm}** → **${__to:date:HH:mm}**"
      }
    },

    {
      "title": "Node CPU Usage",
      "description": "CPU utilisation across all cluster nodes. Above 80% sustained is a warning sign.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",job=\"node-exporter\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 70 },
              { "color": "#F2495C", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "title": "Node Memory Usage",
      "description": "Percentage of physical memory in use across all nodes.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"}))",
          "legendFormat": "Mem %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 75 },
              { "color": "#F2495C", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "title": "Root Disk Usage",
      "description": "Disk space used on the root filesystem of each node.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{job=\"node-exporter\",mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{job=\"node-exporter\",mountpoint=\"/\",fstype!=\"tmpfs\"} * 100)",
          "legendFormat": "Disk %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 70 },
              { "color": "#F2495C", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" }
    },
    {
      "title": "Running Pods",
      "description": "Number of pods currently in Running state in the puresecure namespace.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"puresecure\",phase=\"Running\",job=\"kube-state-metrics\"})",
          "legendFormat": "Running",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "#73BF69", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" }
    },
    {
      "title": "Redis Memory Usage",
      "description": "Current memory consumed by Redis.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "Used",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 100000000 },
              { "color": "#F2495C", "value": 120000000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "title": "Redis Connected Clients",
      "description": "Number of active client connections to Redis.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "redis_connected_clients{job=\"redis\"}",
          "legendFormat": "Clients",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 50 },
              { "color": "#F2495C", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" }
    },

    {
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 8 },
      "options": { "mode": "markdown", "content": "# ⚙️ Node Resources" }
    },
    {
      "title": "Node CPU Usage Over Time",
      "description": "Per-node CPU utilisation over time. Helps identify sustained CPU pressure.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",job=\"node-exporter\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "title": "Node Memory Usage Over Time",
      "description": "Per-node memory utilisation. High sustained memory often precedes OOMKill events.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"}))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "title": "Network I/O — Receive",
      "description": "Bytes per second received across all node network interfaces.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance) (rate(node_network_receive_bytes_total{job=\"node-exporter\",device!~\"lo|veth.*|docker.*|flannel.*|cali.*\"}[5m]))",
          "legendFormat": "{{instance}} rx",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "title": "Network I/O — Transmit",
      "description": "Bytes per second transmitted across all node network interfaces.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance) (rate(node_network_transmit_bytes_total{job=\"node-exporter\",device!~\"lo|veth.*|docker.*|flannel.*|cali.*\"}[5m]))",
          "legendFormat": "{{instance}} tx",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "title": "Disk I/O — Read",
      "description": "Disk read throughput in bytes per second per node.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance) (rate(node_disk_read_bytes_total{job=\"node-exporter\"}[5m]))",
          "legendFormat": "{{instance}} read",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "title": "Disk I/O — Write",
      "description": "Disk write throughput in bytes per second per node.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance) (rate(node_disk_written_bytes_total{job=\"node-exporter\"}[5m]))",
          "legendFormat": "{{instance}} write",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },

    {
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 34 },
      "options": { "mode": "markdown", "content": "# 🐳 Kubernetes — Pod & Container Health" }
    },
    {
      "title": "Pod Status — puresecure namespace",
      "description": "Current phase of every pod in the puresecure namespace.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kube_pod_status_phase{namespace=\"puresecure\",job=\"kube-state-metrics\"}",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "Value": false },
            "renameByName": {
              "pod": "Pod",
              "phase": "Phase",
              "namespace": "Namespace",
              "Value": "Active"
            },
            "indexByName": { "Namespace": 0, "Pod": 1, "Phase": 2, "Active": 3 }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Phase" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "Running": { "text": "Running ✅", "color": "green" },
                      "Pending": { "text": "Pending ⏳", "color": "orange" },
                      "Failed": { "text": "Failed 🔴", "color": "red" },
                      "Unknown": { "text": "Unknown ❓", "color": "gray" }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": { "showHeader": true }
    },
    {
      "title": "Container Restarts (last 1h)",
      "description": "Number of times each container has restarted. Any non-zero value deserves investigation.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"puresecure\",job=\"kube-state-metrics\"}[1h])",
          "legendFormat": "{{pod}} / {{container}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true }
    },
    {
      "title": "Pod CPU Requests vs Limits",
      "description": "Requested and limit CPU for every pod — spot over-provisioned or under-limited workloads.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (pod) (kube_pod_container_resource_requests{namespace=\"puresecure\",resource=\"cpu\",job=\"kube-state-metrics\"})",
          "legendFormat": "{{pod}} req",
          "refId": "A"
        },
        {
          "expr": "sum by (pod) (kube_pod_container_resource_limits{namespace=\"puresecure\",resource=\"cpu\",job=\"kube-state-metrics\"})",
          "legendFormat": "{{pod}} limit",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "displayMode": "basic", "orientation": "horizontal", "showUnfilled": true }
    },
    {
      "title": "Pod Memory Requests vs Limits",
      "description": "Requested and limit memory for every pod.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (pod) (kube_pod_container_resource_requests{namespace=\"puresecure\",resource=\"memory\",job=\"kube-state-metrics\"})",
          "legendFormat": "{{pod}} req",
          "refId": "A"
        },
        {
          "expr": "sum by (pod) (kube_pod_container_resource_limits{namespace=\"puresecure\",resource=\"memory\",job=\"kube-state-metrics\"})",
          "legendFormat": "{{pod}} limit",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "options": { "displayMode": "basic", "orientation": "horizontal", "showUnfilled": true }
    },

    {
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 52 },
      "options": { "mode": "markdown", "content": "# 🗄️ Redis Cache" }
    },
    {
      "title": "Redis Memory Used vs Max",
      "description": "Memory consumed by Redis vs the configured maxmemory limit (128 MiB). Near-full triggers LRU eviction.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 54 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes{job=\"redis\"}",
          "legendFormat": "Max (128 MiB)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Max (128 MiB)" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [10, 5], "fill": "dash" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "title": "Redis Operations Per Second",
      "description": "Total commands processed by Redis per second — reflects cache read/write activity.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 54 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total{job=\"redis\"}[1m])",
          "legendFormat": "ops/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "fixedColor": "#73BF69", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "title": "Redis Cache Hit Rate",
      "description": "Ratio of cache hits to total lookups. Below 90% means the cache is not being used effectively.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 62 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{job=\"redis\"}[5m]) / (rate(redis_keyspace_hits_total{job=\"redis\"}[5m]) + rate(redis_keyspace_misses_total{job=\"redis\"}[5m]))",
          "legendFormat": "Hit Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#FF9830", "value": 0.8 },
              { "color": "#73BF69", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "last"] }
      }
    },
    {
      "title": "Redis Keyspace — Keys Stored",
      "description": "Total number of keys currently held in Redis across all databases.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 62 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(redis_db_keys{job=\"redis\"})",
          "legendFormat": "Keys",
          "refId": "A"
        },
        {
          "expr": "sum(redis_db_keys_expiring{job=\"redis\"})",
          "legendFormat": "Expiring Keys",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] }
      }
    },
    {
      "title": "Redis Evicted & Expired Keys",
      "description": "Keys evicted by LRU policy (bad — cache too small) vs keys expired by TTL (normal).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 70 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(redis_evicted_keys_total{job=\"redis\"}[5m])",
