# ── Azure Entra ID ────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here

# ── Service API Key (Locust / internal tools) ─────────
SERVICE_API_KEY=your-service-api-key-here

# ── Grafana ───────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change-me

# ── Grafana Azure AD OAuth (Microsoft login) ──────────
# Set to true to enable "Sign in with Microsoft" on Grafana
GF_AUTH_AZUREAD_ENABLED=false
# Create in Azure Portal > App registrations > Certificates & secrets
GF_AUTH_AZUREAD_CLIENT_SECRET=your-azure-client-secret-here

# ── CI/CD (GitHub Secrets — do NOT commit real values) ─
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=your-dockerhub-token
SNYK_TOKEN=your-snyk-token
